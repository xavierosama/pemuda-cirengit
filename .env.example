# ============================================================
# APPLICATION
# ============================================================
APP_NAME="Pemuda Cirengit"
APP_ENV=local                   # production di Northflank
APP_KEY=                        # [SECRET] generate via: php artisan key:generate --show
APP_DEBUG=true                  # false di Northflank
APP_URL=http://localhost         # [SECRET] set ke https://<northflank-domain>

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ============================================================
# LOGGING
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # error di Northflank

# ============================================================
# DATABASE (Neon PostgreSQL)
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=ep-red-smoke-ao43bb2j.c-2.ap-southeast-1.aws.neon.tech  # [SECRET] di Northflank
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=                    # [SECRET] set di Northflank
DB_SSLMODE=require

# ============================================================
# SESSION / CACHE / QUEUE
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ============================================================
# REDIS (opsional - tidak dipakai saat ini)
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# MAIL
# ============================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@pemudacirengit.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# AWS (opsional - tidak dipakai saat ini)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# VITE
# ============================================================
VITE_APP_NAME="${APP_NAME}"
