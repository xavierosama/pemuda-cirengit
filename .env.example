# ============================================================
# APPLICATION
# ============================================================
APP_NAME="Pemuda Cirengit"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://domain-anda.com
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ============================================================
# LOGGING
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================================
# DATABASE - cPanel / DomaiNesia MySQL
# Isi sesuai database, user, dan password yang dibuat di cPanel.
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_pemuda_cirengit
DB_USERNAME=cpaneluser_pemuda_user
DB_PASSWORD=

# ============================================================
# SESSION / CACHE / QUEUE
# Tabel sessions, cache, cache_locks, dan jobs dibuat oleh migration.
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# ============================================================
# MAIL
# Untuk tahap awal boleh gunakan log. Ubah ke smtp jika fitur email/reset password dipakai.
# ============================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@domain-anda.com"
MAIL_FROM_NAME="${APP_NAME}"

# Contoh SMTP cPanel jika nanti diperlukan:
# MAIL_MAILER=smtp
# MAIL_HOST=mail.domain-anda.com
# MAIL_PORT=465
# MAIL_USERNAME=noreply@domain-anda.com
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=ssl

# ============================================================
# REDIS / AWS - opsional, tidak dipakai default shared hosting
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# VITE
# ============================================================
VITE_APP_NAME="${APP_NAME}"
